{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/continuity",     "destination": "/continuity_ai/apps/web/index.html" },
    { "source": "/continuity/",    "destination": "/continuity_ai/apps/web/index.html" },
    { "source": "/discovery",      "destination": "/discovery_feed_ai/apps/web/index.html" },
    { "source": "/discovery/",     "destination": "/discovery_feed_ai/apps/web/index.html" },
    { "source": "/animation",      "destination": "/genai_animation_incubator/apps/web/index.html" },
    { "source": "/animation/",     "destination": "/genai_animation_incubator/apps/web/index.html" },
    { "source": "/orchestration",  "destination": "/enterprise_ai_orchestration/apps/web/index.html" },
    { "source": "/orchestration/", "destination": "/enterprise_ai_orchestration/apps/web/index.html" },
    { "source": "/ad-studio",      "destination": "/streaming_ad_creative_studio/apps/web/index.html" },
    { "source": "/ad-studio/",     "destination": "/streaming_ad_creative_studio/apps/web/index.html" },
    { "source": "/live-ads",       "destination": "/live_ads_personalization_engine/apps/web/index.html" },
    { "source": "/live-ads/",      "destination": "/live_ads_personalization_engine/apps/web/index.html" },
    { "source": "/rec-engine",     "destination": "/pluto_paramount_unified_rec_engine/apps/web/index.html" },
    { "source": "/rec-engine/",    "destination": "/pluto_paramount_unified_rec_engine/apps/web/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/_shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
